{
  "name": "marketplace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @marketplace/api --filter @marketplace/web dev",
    "dev:api": "pnpm --filter @marketplace/api dev",
    "dev:web": "pnpm --filter @marketplace/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @marketplace/api db:migrate",
    "db:studio": "pnpm --filter @marketplace/api db:studio"
  }
}
