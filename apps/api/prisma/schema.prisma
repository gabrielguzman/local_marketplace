// Marketplace — schema de datos
// Ver docs/DISENO.md para el razonamiento de cada decisión.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Usuarios y negocios
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String? // null si solo entra por OAuth
  name            String
  phone           String?
  avatarUrl       String?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business           Business?
  addresses          Address[]
  cart               Cart?
  orders             Order[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  reviews            Review[]
  reports            Report[]
  auditLogs          AuditLog[]
  favorites          Favorite[]
  questions          Question[]
  reviewReports      ReviewReport[]
  reviewVotes        ReviewVote[]
  notifications      Notification[]
  messages           Message[]

  @@map("users")
}

enum NotificationType {
  SALE // al vendedor: vendiste un producto
  ORDER_STATUS // al comprador: cambió el estado del envío
  QUESTION // al vendedor: te hicieron una pregunta
  QUESTION_ANSWERED // al comprador: respondieron tu pregunta
  REVIEW_REPLY // al comprador: el vendedor respondió tu reseña
  PAYOUT // al vendedor: se acreditó una liquidación
  MESSAGE // mensaje privado sobre una orden
}

// Notificación in-app para un usuario.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @default("")
  link      String? // ruta destino (ej /compras/<id>, /vender/ventas)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

// Preguntas públicas sobre un producto; el vendedor responde.
model Question {
  id         String    @id @default(uuid())
  productId  String
  authorId   String
  body       String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([productId])
  @@map("questions")
}

// Denuncia de una reseña ofensiva (1 por usuario y reseña).
model ReviewReport {
  id         String   @id @default(uuid())
  reviewId   String
  reporterId String
  createdAt  DateTime @default(now())

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id])

  @@unique([reviewId, reporterId])
  @@map("review_reports")
}

// Productos guardados por un usuario ("guardar para después")
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

// Registro de acciones de moderación: quién hizo qué y a qué.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String // USER_SUSPEND, USER_ROLE, PRODUCT_STATUS, BUSINESS_STATUS, REPORT_RESOLVE
  targetType String // USER | PRODUCT | BUSINESS | REPORT
  targetId   String
  summary    String   @default("")
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@map("audit_logs")
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// Tokens de un solo uso para verificar email / resetear password.
// Igual que los refresh: solo se guarda el hash SHA-256.
model VerificationToken {
  id        String                @id @default(uuid())
  userId    String
  type      VerificationTokenType
  tokenHash String                @unique
  expiresAt DateTime
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

// Refresh tokens opacos, rotativos y de un solo uso.
// Se guarda solo el hash SHA-256; el token va al cliente en cookie httpOnly.
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum BusinessStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Business {
  id          String         @id @default(uuid())
  ownerId     String         @unique // MVP: 1 negocio por usuario
  name        String
  slug        String         @unique
  description String         @default("")
  logoUrl     String?
  bannerUrl   String?
  // Contacto
  phone     String?
  whatsapp  String?
  email     String?
  website   String?
  instagram String?
  // Ubicación
  address  String?
  city     String?
  province String?
  // Operación
  hours    String? // horarios, texto libre
  policies String? // políticas de la tienda, texto libre
  // Envíos
  pickupEnabled Boolean @default(false) // retiro en persona
  shippingCents Int? // costo fijo de envío; null = no ofrece envío
  status      BusinessStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id])
  products  Product[]
  subOrders SubOrder[]
  reviews   Review[]
  payouts   Payout[]

  @@map("businesses")
}

model Address {
  id        String  @id @default(uuid())
  userId    String
  street    String
  number    String
  city      String
  province  String
  zipCode   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// Catálogo
// ─────────────────────────────────────────────

model Category {
  id       String  @id @default(uuid())
  parentId String?
  name     String
  slug     String  @unique

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  DELETED // soft delete: las órdenes históricas lo referencian vía snapshot
}

enum ProductCondition {
  NEW
  USED
}

model Product {
  id          String           @id @default(uuid())
  businessId  String
  categoryId  String
  title       String
  slug        String           @unique
  description String           @default("")
  brand       String?
  condition   ProductCondition @default(NEW)
  // Ficha técnica: [{"key":"Material","value":"Aluminio"}, ...] (array para
  // conservar el orden; jsonb no preserva el orden de las claves de un objeto)
  specs       Json             @default("[]")
  status      ProductStatus    @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Columna generada por migración SQL manual:
  // GENERATED ALWAYS AS (to_tsvector('spanish', title || ' ' || description)) STORED
  searchVector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('spanish'::regconfig, ((COALESCE(title, ''::text) || ' '::text) || COALESCE(description, ''::text)))"))

  business  Business         @relation(fields: [businessId], references: [id])
  category  Category         @relation(fields: [categoryId], references: [id])
  variants  ProductVariant[]
  images    ProductImage[]
  reviews   Review[]
  reports   Report[]
  favorites Favorite[]
  questions Question[]

  @@index([businessId])
  @@index([categoryId])
  @@index([status])
  @@index([searchVector], type: Gin)
  @@map("products")
}

model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  sku        String?
  // {"color": "rojo", "talle": "M"} — todo producto tiene al menos la variante default
  attributes Json    @default("{}")
  priceCents Int // dinero SIEMPRE en centavos, nunca floats
  currency   String  @default("ARS")
  stock      Int     @default(0)
  isDefault  Boolean @default(false)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────
// Carrito
// ─────────────────────────────────────────────

// Un carrito pertenece a un usuario logueado (userId) o a un invitado
// identificado por guestToken (cookie httpOnly). Exactamente uno de los dos.
model Cart {
  id         String   @id @default(uuid())
  userId     String?  @unique
  guestToken String?  @unique
  updatedAt  DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// Órdenes y pagos
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ShippingMethod {
  PICKUP // retiro en persona
  SHIPPING // envío a domicilio
  TO_AGREE // a coordinar con el vendedor
}

model Order {
  id     String      @id @default(uuid())
  buyerId String
  status OrderStatus @default(PENDING_PAYMENT)

  totalCents    Int
  shippingCents Int    @default(0) // suma de envíos de las sub-órdenes
  currency      String @default("ARS")

  // Snapshot de la dirección al momento de la compra
  shippingAddress Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer     User       @relation(fields: [buyerId], references: [id])
  subOrders SubOrder[]
  payment   Payment?

  @@index([buyerId])
  @@map("orders")
}

model SubOrder {
  id             String         @id @default(uuid())
  orderId        String
  businessId     String
  status         SubOrderStatus @default(PENDING)
  subtotalCents  Int // sólo productos (sin envío)
  shippingMethod ShippingMethod @default(TO_AGREE)
  shippingCents  Int            @default(0)
  feeCents       Int            @default(0) // comisión de la plataforma
  trackingCode   String? // número de seguimiento (al marcar enviada)
  cancelReason   String? // motivo si el vendedor la cancela
  payoutId       String? // liquidación que incluyó esta venta (null = sin liquidar)

  order    Order       @relation(fields: [orderId], references: [id])
  business Business    @relation(fields: [businessId], references: [id])
  items    OrderItem[]
  payout   Payout?     @relation(fields: [payoutId], references: [id])
  messages Message[]

  @@index([orderId])
  @@index([businessId])
  @@index([payoutId])
  @@map("sub_orders")
}

// Mensaje privado entre el comprador y el vendedor sobre una venta (sub-orden).
// readAt = cuándo lo leyó el destinatario (el otro participante del hilo).
model Message {
  id         String   @id @default(uuid())
  subOrderId String
  senderId   String
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  subOrder SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([subOrderId, createdAt])
  @@map("messages")
}

// Liquidación: registro de un pago al vendedor por sus ventas entregadas
// (neto = subtotal − comisión + envío). El pago real es manual (transferencia);
// acá queda el comprobante y las sub-órdenes que cubrió.
model Payout {
  id          String   @id @default(uuid())
  businessId  String
  amountCents Int // neto liquidado al vendedor
  note        String? // referencia de la transferencia
  createdAt   DateTime @default(now())

  business  Business   @relation(fields: [businessId], references: [id])
  subOrders SubOrder[]

  @@index([businessId])
  @@map("payouts")
}

model OrderItem {
  id         String @id @default(uuid())
  subOrderId String
  variantId  String
  quantity   Int

  // Snapshots al momento de compra: la orden no cambia si editan el producto
  unitPriceCents     Int
  titleSnapshot      String
  attributesSnapshot Json   @default("{}")

  subOrder SubOrder       @relation(fields: [subOrderId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@index([subOrderId])
  @@map("order_items")
}

// ─────────────────────────────────────────────
// Confianza: reseñas y denuncias
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid())
  productId  String
  businessId String // denormalizado para calcular reputación de la tienda
  authorId   String
  rating     Int // 1..5, validado en la API
  comment    String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Respuesta pública del vendedor a la reseña
  sellerResponse    String?
  sellerRespondedAt DateTime?

  product  Product        @relation(fields: [productId], references: [id])
  business Business       @relation(fields: [businessId], references: [id])
  author   User           @relation(fields: [authorId], references: [id])
  reports  ReviewReport[]
  votes    ReviewVote[]

  @@unique([productId, authorId]) // una reseña por usuario y producto
  @@index([businessId])
  @@map("reviews")
}

// Voto "me resultó útil" de un usuario sobre una reseña (1 por usuario)
model ReviewVote {
  id        String   @id @default(uuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
  @@map("review_votes")
}

enum ReportReason {
  SPAM
  PROHIBITED
  COUNTERFEIT
  OFFENSIVE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id         String       @id @default(uuid())
  productId  String
  reporterId String
  reason     ReportReason
  details    String       @default("")
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  product  Product @relation(fields: [productId], references: [id])
  reporter User    @relation(fields: [reporterId], references: [id])

  @@unique([productId, reporterId]) // una denuncia por usuario y producto
  @@index([status])
  @@map("reports")
}

enum PaymentProvider {
  MERCADOPAGO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model Payment {
  id                String          @id @default(uuid())
  orderId           String          @unique
  provider          PaymentProvider @default(MERCADOPAGO)
  providerPaymentId String?         @unique // clave de idempotencia del webhook
  status            PaymentStatus   @default(PENDING)
  amountCents       Int
  rawWebhookPayload Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}
