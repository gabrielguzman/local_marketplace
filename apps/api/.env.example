# Copiar a .env y completar

# Postgres local. Ojo: la instancia 17 de esta máquina corre en 5433
# (el 5432 lo ocupa un Postgres 18 preexistente).
DATABASE_URL="postgresql://marketplace:marketplace@localhost:5433/marketplace"

PORT=3001
WEB_URL="http://localhost:3000"

# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="cambiame-por-un-secreto-largo"
JWT_ACCESS_TTL="15m"
